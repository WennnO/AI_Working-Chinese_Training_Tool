# OpenAI API key. Never commit your real key.
OPENAI_API_KEY=replace_with_your_openai_api_key

# Text correction and report rewriting model.
OPENAI_TEXT_MODEL=gpt-5.4-mini

# Speech-to-text model for browser recordings.
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Base model used when creating a fine-tuning job.
FINE_TUNE_BASE_MODEL=gpt-4.1-mini-2025-04-14

# Local app settings.
DATABASE_URL=file:./dev.db
PORT=8787
CLIENT_ORIGIN=http://localhost:5173